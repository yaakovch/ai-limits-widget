{
  "name": "ai-limits-widget",
  "version": "0.9.0-beta.1",
  "description": "Windows desktop widget for Codex and Claude Code usage limits.",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "author": "Yaakov Chen Zion",
  "repository": "https://github.com/yaakovch/ai-limits-widget",
  "homepage": "https://github.com/yaakovch/ai-limits-widget",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder --win nsis portable --x64 --publish never",
    "package:dir": "npm run build && electron-builder --win dir --x64 --publish never",
    "sbom": "cyclonedx-npm --output-file dist/bom.json --spec-version 1.6",
    "preview": "electron-vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run --dir tests",
    "smoke:packaged": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-packaged.ps1",
    "finalize:release": "node scripts/finalize-release.mjs"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@electron/fuses": "^2.1.3",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@esbuild/win32-x64@0.25.12": true,
    "@esbuild/win32-x64@0.28.1": true
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lucide": "^1.24.0"
  }
}
