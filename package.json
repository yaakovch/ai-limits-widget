{
  "name": "agent-fleet",
  "version": "0.11.0-beta.22",
  "description": "Windows tray dashboard for local AI coding sessions, schedules, hosts, and usage limits.",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "author": "Yaakov Chen Zion",
  "repository": "https://github.com/yaakovch/agent-fleet",
  "homepage": "https://github.com/yaakovch/agent-fleet",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run verify:runtime && electron-vite build",
    "verify:runtime": "node scripts/verify-embedded-runtime.mjs",
    "package": "npm run build && electron-builder --win nsis portable --x64 --publish never",
    "package:dir": "npm run build && electron-builder --win dir --x64 --publish never",
    "sbom": "cyclonedx-npm --output-file dist/bom.json --spec-version 1.6",
    "preview": "electron-vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run --dir tests",
    "smoke:packaged": "node scripts/run-powershell.mjs scripts/smoke-packaged.ps1",
    "finalize:release": "node scripts/finalize-release.mjs"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@electron/fuses": "^2.1.3",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@esbuild/win32-x64@0.25.12": true,
    "@esbuild/win32-x64@0.28.1": true
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^8.0.0",
    "dompurify": "^3.4.12",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "lucide": "^1.24.0",
    "marked": "^18.0.6",
    "node-pty": "^1.1.0"
  }
}
